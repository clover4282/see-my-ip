      <sparkle:version>1</sparkle:version>
      <sparkle:shortVersionString>0.1</sparkle:shortVersionString>
      <sparkle:minimumSystemVersion>14.0</sparkle:minimumSystemVersion>
      <description><![CDATA[
        <h2>See My IP v0.1</h2>
        <p>Initial release</p>
        <ul>
          <li>Public IP detection with multiple provider fallback</li>
          <li>Local network interfaces (IPv4/IPv6)</li>
          <li>GeoLocation (country, city, ISP, timezone)</li>
          <li>VPN detection</li>
          <li>IP change history and notifications</li>
          <li>Customizable menu bar display modes</li>
          <li>Manual update check via GitHub Releases</li>
          <li>Power-optimized design</li>
        </ul>
      ]]></description>
